#include "stm32l476xx_gpio_driver.h"
#include "stm32l476xx_uart_driver.h"
#include <stdint.h>
#include <string.h>


void delay(void);


int main(void)
{

	char msg[] = "BareMetal UART DMA Test\r\n";

	    UART2_GPIOInits();

	    UART2_Init();

	    DMA1_Init();
	    while(1)
	    {
	        UART_SendData((uint8_t*)msg,strlen(msg));

	        delay();
	    }
}
void delay(void)
{
    for(uint32_t i = 0; i < 500000/2; i++);
}
