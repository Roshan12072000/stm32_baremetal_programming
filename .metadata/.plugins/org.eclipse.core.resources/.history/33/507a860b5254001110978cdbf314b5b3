/****************************************************************
 * ERASE SECTOR
 ***************************************************************/
void W25Q_EraseSector(uint32_t addr)
{
    uint8_t cmd[4];

    W25Q_WriteEnable();

    cmd[0] = 0x20;

    cmd[1] = (addr >> 16) & 0xFF;
    cmd[2] = (addr >> 8) & 0xFF;
    cmd[3] = addr & 0xFF;

    CS_LOW();

    SPI_SendData(SPI1, cmd, 4);

    while(SPI_GetFlagStatus(SPI1, SPI_BUSY_FLAG));

    CS_HIGH();

    W25Q_WaitBusy();
}

/****************************************************************
 * WRITE DATA
 ***************************************************************/
void W25Q_Write(uint32_t addr, uint8_t *data, uint16_t len)
{
    uint8_t cmd[4];

    W25Q_WriteEnable();

    cmd[0] = 0x02;

    cmd[1] = (addr >> 16) & 0xFF;
    cmd[2] = (addr >> 8) & 0xFF;
    cmd[3] = addr & 0xFF;

    CS_LOW();

    SPI_SendData(SPI1, cmd, 4);

    SPI_SendData(SPI1, data, len);

    while(SPI_GetFlagStatus(SPI1, SPI_BUSY_FLAG));

    CS_HIGH();

    W25Q_WaitBusy();
}

/****************************************************************
 * READ DATA
 ***************************************************************/
void W25Q_Read(uint32_t addr, uint8_t *data, uint16_t len)
{
    uint8_t cmd[4];

    cmd[0] = 0x03;

    cmd[1] = (addr >> 16) & 0xFF;
    cmd[2] = (addr >> 8) & 0xFF;
    cmd[3] = addr & 0xFF;

    CS_LOW();

    SPI_SendData(SPI1, cmd, 4);

    SPI_ReceiveData(SPI1, data, len);

    while(SPI_GetFlagStatus(SPI1, SPI_BUSY_FLAG));

    CS_HIGH();
}

void Store_Lux(uint16_t lux)
{
    uint32_t addr;

//    if(write_index == 0)
//       {
//           W25Q_EraseSector(FLASH_BASE_ADDR);
//       }

    addr =
      FLASH_BASE_ADDR +
      (write_index * 2);

    W25Q_Write(addr,
                  (uint8_t*)&lux,
                  2);

    write_index++;

    if(write_index >= MAX_LOGS)
    {
        write_index = 0;
    }

    if(total_logs < MAX_LOGS)
    {
        total_logs++;
    }
}
void Print_Recent_Logs(void)
{
    int8_t idx;

    uint16_t lux;

    char msg[50];

    idx = write_index - 1;

    if(idx < 0)
    {
        idx = MAX_LOGS - 1;
    }

    for(uint8_t i = 0;
        i < total_logs;
        i++)
    {
        uint32_t addr;

        addr =
          FLASH_BASE_ADDR +
          (idx * 2);

        W25Q_Read(addr,
                     (uint8_t*)&lux,
                     2);

        sprintf(msg,
                "Lux = %d\r\n",
                lux);

        UART_SendData((uint8_t*)msg,
                      strlen(msg));

        idx--;

        if(idx < 0)
        {
            idx = MAX_LOGS - 1;
        }
    }
}
