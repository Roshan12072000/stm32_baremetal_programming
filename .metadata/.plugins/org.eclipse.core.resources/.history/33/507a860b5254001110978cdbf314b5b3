uint8_t config[3];
uint8_t reg = 0x00;
uint8_t data[2];

uint16_t raw;
uint16_t exponent;
uint16_t mantissa;
uint8_t reg_addr = 0x00;
uint8_t sensor_data;int lux;
int main(void)
{
    /*
     * UART INIT
     */
    UART2_GPIOInits();

    UART2_Init();

    /*
     * GPIO INTERRUPT INIT
     */
    gpio_pin_init();

    /*
     * SPI INIT
     */
    SPI_GPIO_Init();

    SPI1_Inits();
    SPI_PeripheralControl(SPI1, ENABLE);
    /*
     * I2C INIT
     */
    I2C1_GPIOInits();

    I2C1_Inits();

    /*
     * ERASE FLASH SECTOR
     */
    W25Q_EraseSector(FLASH_BASE_ADDR);

    while(1)
    {
        /************************************************
         * SENSOR CONFIG
         ***********************************************/
        config[0] = 0x01;
        config[1] = 0xC4;
        config[2] = 0x10;

        I2C_MasterSendData(&I2C1Handle,
                           config,
                           3,
                           0x47);

        delay();

        /************************************************
         * SELECT RESULT REGISTER
         ***********************************************/
        I2C_MasterSendData(&I2C1Handle,
                           &reg,
                           1,
                           0x47);

        /************************************************
         * READ SENSOR DATA
         ***********************************************/
        I2C_MasterReceiveData(&I2C1Handle,
                              data,
                              2,
                              0x47);

        /************************************************
         * LUX CALCULATION
         ***********************************************/
        raw =
          (data[0] << 8) | data[1];

        exponent =
          (raw >> 12) & 0x0F;

        mantissa =
          raw & 0x0FFF;

        lux =
          (mantissa * (1 << exponent)) / 100;

        /************************************************
         * STORE INTO FLASH
         ***********************************************/
        sprintf(msg,
                "Lux = %d\r\n",
                lux);

        UART_SendData((uint8_t*)msg,
                      strlen(msg));
        Store_Lux(lux);

        delay();
    }
}

